{
    "manifest_version": 3,
    "name": "JobCompass",
    "version": "1.0",
    "description": "Extract job details from any posting and log to JobCompass instantly.",

    "background": {
        "service_worker": "background.js"
    },

    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "images/icon16.png",
            "32": "images/icon32.png",
            "48": "images/icon48.png"
        }
    },

    "permissions": [
        "activeTab",
        "scripting",
        "nativeMessaging"
    ],

    "content_scripts": [
        {
            "matches": [
                "*://*.linkedin.com/jobs/*",
                "*://*.indeed.com/viewjob*",
                "*://*.glassdoor.com/job-listing/*",
                "*://*.greenhouse.io/*/jobs/*",
                "*://boards.greenhouse.io/*",
                "*://*.lever.co/*",
                "*://*.workday.com/*",
                "*://*.myworkdayjobs.com/*",
                "*://*.smartrecruiters.com/*",
                "*://*.jobs.ashbyhq.com/*",
                "*://*.otta.com/jobs/*",
                "*://*.welcometothejungle.com/*/jobs/*"
            ],
            "js": ["content.js"],
            "run_at": "document_idle"
        }
    ]
}
